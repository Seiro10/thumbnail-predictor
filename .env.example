# YouTube Data API v3
# Get yours at https://console.cloud.google.com/apis/api/youtube.googleapis.com
API_KEY_YOUTUBE=your_youtube_api_key_here

# Google Cloud Platform
GCP_PROJECT=your-gcp-project-id
GCP_REGION=europe-west1

# Google Cloud Storage bucket for model artifacts
GCS_BUCKET=your-gcs-bucket-name

# Vertex AI — Model ID returned after running vertex/export_savedmodel.py
VERTEX_MODEL_ID=your_vertex_model_id_here
